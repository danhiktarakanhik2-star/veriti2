{
	"format_version": "1.21.0",
	"minecraft:entity": {
		"description": {
			"identifier": "pntmc:verityball",
			"is_spawnable": false,
			"is_summonable": true,
			"is_experimental": false,
			"properties": {
				"pntmc:face_index": {
					"type": "int",
					"range": [0, 11],
					"default": 0,
					"client_sync": true
				},
				"pntmc:talking": {
					"type": "bool",
					"default": false,
					"client_sync": true
				},
				"pntmc:scolding": {
					"type": "bool",
					"default": false,
					"client_sync": true
				},
				"pntmc:moving": {
					"type": "bool",
					"default": false,
					"client_sync": true
				},
				"pntmc:faceless": {
					"type": "bool",
					"default": false,
					"client_sync": true
				}
			}
		},
		"component_groups": {
			"pntmc:pickup_ping": {}
		},
		"components": {
			"minecraft:type_family": {
				"family": ["pntmc", "inanimate", "verityball"]
			},
			"minecraft:collision_box": {
				"width": 0.2,
				"height": 0.2
			},
			"minecraft:custom_hit_test": {
				"hitboxes": [
					{
						"width": 0.6,
						"height": 0.6,
						"pivot": [0, 0.25, 0]
					}
				]
			},
			"minecraft:interact": {
				"interactions": [
					{
						"swing": true,
						"use_item": false,
						"interact_text": "action.interact.pickup",
						"on_interact": {
							"filters": {
								"all_of": [
									{
										"test": "is_family",
										"subject": "other",
										"value": "player"
									}
								]
							},
							"event": "pntmc:pickup",
							"target": "self"
						}
					}
				]
			},
			"minecraft:damage_sensor": {
				"triggers": [
					{
						"deals_damage": false
					}
				]
			},
			"minecraft:health": {
				"value": 10000,
				"max": 10000
			},
			"minecraft:knockback_resistance": {
				"value": 1.0
			},
			"minecraft:physics": {},
			"minecraft:pushable": {
				"is_pushable": false,
				"is_pushable_by_piston": false
			},
			"minecraft:loot": {
				"table": "loot_tables/empty.json"
			}
		},
		"events": {
			"pntmc:pickup": {
				"add": {
					"component_groups": ["pntmc:pickup_ping"]
				},
				"remove": {
					"component_groups": ["pntmc:pickup_ping"]
				}
			}
		}
	}
}
