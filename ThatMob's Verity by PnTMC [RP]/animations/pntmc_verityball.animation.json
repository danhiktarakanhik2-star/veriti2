		"animation.pntmc_verityball.talk_pulse": {
			"loop": true,
			"anim_time_update": "query.anim_time + query.delta_time",
			"bones": {
				"ball": {
					"scale": [
						"1 - math.abs(math.sin(query.anim_time * math.pi * v.talk_speed)) * 0.20",
						"1 + math.abs(math.sin(query.anim_time * math.pi * v.talk_speed)) * 0.45",
						"1 - math.abs(math.sin(query.anim_time * math.pi * v.talk_speed)) * 0.20"
					]
				}
			}
		},
		"animation.pntmc_verityball.look_at_target": {
			"loop": true,
