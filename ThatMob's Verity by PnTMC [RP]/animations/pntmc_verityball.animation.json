				"ball": {
					"relative_to": {
						"rotation": "entity"
					},
					"rotation": [
						"q.rotation_to_camera(0) * math.clamp(query.distance_from_camera / 2.5, 0.12, 0.55)",
						"-query.body_y_rotation + q.rotation_to_camera(1)",
						0
					]
				}
			}
		},
