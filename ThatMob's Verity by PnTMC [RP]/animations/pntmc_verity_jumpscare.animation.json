{
	"format_version": "1.8.0",
	"animations": {
		"animation.pntmc_verity_jumpscare.look_at_target": {
			"loop": true,
			"bones": {
				"root": {
					"relative_to": {
						"rotation": "entity"
					},
					"rotation": ["q.rotation_to_camera(0) * 0.15", "-query.body_y_rotation + query.rotation_to_camera(1)", 0]
				}
			}
		},
		"animation.pntmc_verity_jumpscare.window_scare": {
			"animation_length": 30,
			"bones": {
				"root": {
					"position": {
						"0.0": {
							"post": [0, 0, 0],
							"lerp_mode": "catmullrom"
						},
						"0.3": {
							"post": [0, 0, -8],
							"lerp_mode": "catmullrom"
						},
						"1.8": {
							"post": [0, 0, -8],
							"lerp_mode": "catmullrom"
						}
					},
					"scale": {
						"0.0": [1, 1, 1],
						"0.2": [1.08, 1.08, 1],
						"1.8": [1.08, 1.08, 1]
					}
				}
			}
		}
	}
}