{
	"format_version": "1.10.0",
	"particle_effect": {
		"description": {
			"identifier": "pntmc:verityopen",
			"basic_render_parameters": {
				"material": "particles_alpha",
				"texture": "textures/particle/verityopen"
			}
		},
		"components": {
			"minecraft:emitter_rate_instant": {
				"num_particles": 60
			},
			"minecraft:emitter_lifetime_once": {
				"active_time": 1
			},
			"minecraft:emitter_shape_sphere": {
				"radius": 0.4,
				"direction": "outwards"
			},
			"minecraft:particle_lifetime_expression": {
				"max_lifetime": "0.8 + 0.4 * variable.particle_random_3"
			},
			"minecraft:particle_initial_speed": 1,
			"minecraft:particle_motion_dynamic": {
				"linear_drag_coefficient": 2
			},
			"minecraft:particle_appearance_billboard": {
				"size": [
					"(0.2 + 0.2 * variable.particle_random_1) * (1 - variable.particle_age / variable.particle_lifetime)",
					"(0.2 + 0.2 * variable.particle_random_1) * (1 - variable.particle_age / variable.particle_lifetime)"
				],
				"facing_camera_mode": "rotate_xyz",
				"uv": {
					"texture_width": 128,
					"texture_height": 128,
					"uv": [0, 0],
					"uv_size": [128, 128]
				}
			},
			"minecraft:particle_appearance_tinting": {
				"color": [
					"0.5 + 0.5 * variable.particle_random_2",
					"0.5 + 0.5 * variable.particle_random_2",
					"0.5 + 0.5 * variable.particle_random_2",
					"1 - variable.particle_age / variable.particle_lifetime"
				]
			}
		}
	}
}
