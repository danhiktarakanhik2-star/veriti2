{
	"format_version": "1.10.0",
	"render_controllers": {
		"controller.render.pntmc_verityball": {
			"geometry": "Geometry.default",
			"materials": [
				{
					"*": "Material.default"
				}
			],
			"textures": [
				"query.property('pntmc:faceless') ? Texture.face_blank : Array.faces[math.clamp(query.property('pntmc:face_index'), 0, 11)]"
			],
			"arrays": {
				"textures": {
					"Array.faces": [
						"Texture.face1",
						"Texture.face2",
						"Texture.face3",
						"Texture.face4",
						"Texture.face5",
						"Texture.face6",
						"Texture.face7",
						"Texture.face8",
						"Texture.face_creepysmile",
						"Texture.face_serious1",
						"Texture.face_serious2",
						"Texture.face_serious3"
					]
				}
			}
		}
	}
}
